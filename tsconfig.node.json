{
	// Tooling project: everything that runs under Bun, not in the browser —
	// the Vite config and the build/icon scripts. Gets Bun globals (Bun.*, etc.)
	// via @types/bun and no DOM libs.
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",

		// Environment & language level
		"target": "ESNext",
		"lib": ["ESNext"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"moduleDetection": "force",

		// Bundler mode (no emit — Bun executes the .ts directly)
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,

		// Bun runtime globals only.
		"types": ["bun"],

		// Strictness
		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false
	},
	"include": ["vite.config.ts", "scripts/**/*.ts"]
}
