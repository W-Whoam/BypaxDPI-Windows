{
	// Solution-style root config. It owns no files itself — it only wires the two
	// real environments together so `tsc --build` type-checks both:
	//   - tsconfig.app.json  → the browser/React frontend (src/)
	//   - tsconfig.node.json → Bun-run tooling (vite.config.ts, scripts/, change-icon.ts)
	// These environments have incompatible globals (DOM vs Bun) and must NOT share
	// one config. See ARCHITECTURE.md § Toolchain.
	"files": [],
	"references": [
		{ "path": "./tsconfig.app.json" },
		{ "path": "./tsconfig.node.json" }
	]
}
