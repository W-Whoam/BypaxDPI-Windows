{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "allowJs": false,

    // Only add if using JSX (e.g. React, @elysiajs/html)
    // "jsx": "react-jsx",

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true, // Drop if building a library
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Add bun-types here OR via @types/bun package, not both
    "types": ["bun-types"],

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Disabled by default — enable if you want stricter hygiene
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": ["src/**/*", "scripts/**/*"]
}
